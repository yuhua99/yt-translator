{
  "manifest_version": 3,
  "name": "Simple Translator",
  "description": "Basic Chrome extension template using TypeScript, Bun, and oxlint.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Simple Translator"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://www.youtube.com/*"]
}
